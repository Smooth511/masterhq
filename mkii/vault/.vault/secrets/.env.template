# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  mk2-phantom SECRETS TEMPLATE                                            ║
# ║  Copy this to .env (same directory) and fill in real values.             ║
# ║  .env is gitignored globally — it will NEVER be committed.               ║
# ║  This template is tracked so agents know what keys are expected.         ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── GitHub ────────────────────────────────────────────────────────────────
# Personal access token — needs repo scope for private repo access
# Generate at: https://github.com/settings/tokens/new
# Required scopes: repo (full), read:org
GITHUB_TOKEN=

# ── MCP Server ────────────────────────────────────────────────────────────
# Set if you want the MCP server to authenticate requests
# Leave blank for local-only / VS Code stdio transport (no auth needed)
MCP_SECRET_KEY=

# ── Investigation Tools ───────────────────────────────────────────────────
# Path overrides for evidence directories (leave blank to use repo defaults)
EVIDENCE_DIR=
LOGS_DIR=

# ── Future / TBD ──────────────────────────────────────────────────────────
# Add keys here as they're needed. Keep this file updated.
# If a tool needs a key, it goes here first, then the actual value goes in .env

# ── Usage in code ─────────────────────────────────────────────────────────
# Python:  import os; token = os.environ.get("GITHUB_TOKEN")
# Shell:   source mk2-phantom/.vault/secrets/.env && echo $GITHUB_TOKEN
# Node:    process.env.GITHUB_TOKEN
